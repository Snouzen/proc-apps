generator client {
  provider        = "prisma-client-js"
  output          = "../server/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

generator client_app {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                 String              @id
  name               String              @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime
  satuanKg           Float               @default(1)
  PurchaseOrderItems PurchaseOrderItem[]
  DataRetur          DataRetur[]
}

model PurchaseOrder {
  id             String              @id
  ritelId        String
  unitProduksiId String
  noPo           String              @unique
  tglPo          DateTime
  expiredTgl     DateTime?
  linkPo         String?
  noInvoice      String?
  tujuanDetail   String?
  regional       String?
  statusKirim    Boolean             @default(false)
  statusSdif     Boolean             @default(false)
  statusPo       Boolean             @default(false)
  statusFp       Boolean             @default(false)
  statusKwi      Boolean             @default(false)
  statusInv      Boolean             @default(false)
  statusTagih    Boolean             @default(false)
  statusBayar    Boolean             @default(false)
  remarks        String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime
  tglkirim       DateTime?
  buktiBayar     String?
  buktiTagih     String?
  buktiKirim     String?
  buktiFp        String?
  namaSupir      String?
  platNomor      String?
  RitelModern    RitelModern         @relation(fields: [ritelId], references: [id])
  UnitProduksi   UnitProduksi        @relation(fields: [unitProduksiId], references: [idRegional])
  Items          PurchaseOrderItem[]

  // Performance indexes for dashboard/schedule/company queries
  @@index([noInvoice])              // status filters (active/completed/expired)
  @@index([expiredTgl])             // expired/almost_expired filters
  @@index([tglPo])                  // date range + sorting
  @@index([createdAt])              // sorting by newest
  @@index([regional])               // regional filter
  @@index([ritelId])                // company joins
  @@index([unitProduksiId])         // unit produksi joins
  @@index([tglkirim])               // schedule page filter
  @@index([noInvoice, expiredTgl])  // compound: active PO queries
}

model PurchaseOrderItem {
  id              String        @id
  purchaseOrderId String
  productId       String
  pcs             Int
  pcsKirim        Int
  hargaKg         Float
  hargaPcs        Float
  nominal         Float
  rpTagih         Float
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  discount        Float         @default(0)
  Product         Product       @relation(fields: [productId], references: [id])
  PurchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])  // aggregation joins (attachSummary)
  @@index([productId])        // product joins
}

model RitelModern {
  id            String          @id
  namaPt        String
  inisial       String?
  tujuan        String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  PurchaseOrder PurchaseOrder[]
  DataRetur     DataRetur[]

  @@index([namaPt])  // company grouping/filtering
  @@map("ritel_modern")
}

model UnitProduksi {
  idRegional    String          @id @default(cuid())
  namaRegional  String
  siteArea      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  alamat        String?         @default("")
  PurchaseOrder       PurchaseOrder[]
  LokasiReturs        DataRetur[]     @relation("LokasiRetur")
  PembebananReturs    DataRetur[]     @relation("PembebananRetur")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("pic_site")
  regional  String?
  siteArea  String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model DataRetur {
  id                  String        @id @default(cuid())
  rtvCn               String?
  tanggalRtv          DateTime?
  maxPickup           DateTime?
  kodeToko            Int?
  namaCompany         String?
  ritelId             String?
  RitelModern         RitelModern?  @relation(fields: [ritelId], references: [id])
  link                String?
  produk              String?
  productId           String?
  Product             Product?      @relation(fields: [productId], references: [id])
  qtyReturn           Int?
  nominal             Decimal?
  rpKg                Decimal?
  statusBarang        String? // "sudah diambil" | "dimusnahkan"
  refKetStatus        String?
  lokasiBarangId      String?
  LokasiBarang        UnitProduksi? @relation("LokasiRetur", fields: [lokasiBarangId], references: [idRegional])
  pembebananReturnId  String?
  PembebananReturn    UnitProduksi? @relation("PembebananRetur", fields: [pembebananReturnId], references: [idRegional])
  invoiceRekon        Boolean?      @default(false)
  referensiPembayaran String?
  tanggalPembayaran   DateTime?
  remarks             String?
  sdiReturn           String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@map("data_retur")
}